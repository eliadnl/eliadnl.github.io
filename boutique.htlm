<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Boutique - L'Atelier d'Elia</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <header>
    <h1>L'Atelier d'Elia</h1>
    <nav>
      <a href="index.html">Accueil</a>
      <a href="boutique.html">Boutique</a>
      <a href="contact.html">Contact</a>
    </nav>
  </header>

  <main>
    <h2>Collection : Illustration Chrétienne N°1</h2>
    <p>Chaque illustration est disponible en 3 couleurs : Vert, Bleu, Rose.<br>
       Vous pouvez choisir entre Sticker (1,50€) ou Carte (3€).</p>

    <h3>Colombes</h3>
    <div class="product">
      <img src="images/colombes_vert_sticker.jpg" alt="Colombes Vert Sticker">
      <p>Sticker Vert - 1,50€</p>
      <button onclick="addToCart('Colombes Vert Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/colombes_vert_carte.jpg" alt="Colombes Vert Carte">
      <p>Carte Vert - 3€</p>
      <button onclick="addToCart('Colombes Vert Carte', 3)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/colombes_bleu_sticker.jpg" alt="Colombes Bleu Sticker">
      <p>Sticker Bleu - 1,50€</p>
      <button onclick="addToCart('Colombes Bleu Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/colombes_bleu_carte.jpg" alt="Colombes Bleu Carte">
      <p>Carte Bleu - 3€</p>
      <button onclick="addToCart('Colombes Bleu Carte', 3)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/colombes_rose_sticker.jpg" alt="Colombes Rose Sticker">
      <p>Sticker Rose - 1,50€</p>
      <button onclick="addToCart('Colombes Rose Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/colombes_rose_carte.jpg" alt="Colombes Rose Carte">
      <p>Carte Rose - 3€</p>
      <button onclick="addToCart('Colombes Rose Carte', 3)">Ajouter au panier</button>
    </div>

    <h3>Adoration</h3>
    <div class="product">
      <img src="images/adoration_vert_sticker.jpg" alt="Adoration Vert Sticker">
      <p>Sticker Vert - 1,50€</p>
      <button onclick="addToCart('Adoration Vert Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/adoration_vert_carte.jpg" alt="Adoration Vert Carte">
      <p>Carte Vert - 3€</p>
      <button onclick="addToCart('Adoration Vert Carte', 3)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/adoration_bleu_sticker.jpg" alt="Adoration Bleu Sticker">
      <p>Sticker Bleu - 1,50€</p>
      <button onclick="addToCart('Adoration Bleu Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/adoration_bleu_carte.jpg" alt="Adoration Bleu Carte">
      <p>Carte Bleu - 3€</p>
      <button onclick="addToCart('Adoration Bleu Carte', 3)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/adoration_rose_sticker.jpg" alt="Adoration Rose Sticker">
      <p>Sticker Rose - 1,50€</p>
      <button onclick="addToCart('Adoration Rose Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/adoration_rose_carte.jpg" alt="Adoration Rose Carte">
      <p>Carte Rose - 3€</p>
      <button onclick="addToCart('Adoration Rose Carte', 3)">Ajouter au panier</button>
    </div>

    <h3>Bougies</h3>
    <div class="product">
      <img src="images/bougies_vert_sticker.jpg" alt="Bougies Vert Sticker">
      <p>Sticker Vert - 1,50€</p>
      <button onclick="addToCart('Bougies Vert Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/bougies_vert_carte.jpg" alt="Bougies Vert Carte">
      <p>Carte Vert - 3€</p>
      <button onclick="addToCart('Bougies Vert Carte', 3)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/bougies_bleu_sticker.jpg" alt="Bougies Bleu Sticker">
      <p>Sticker Bleu - 1,50€</p>
      <button onclick="addToCart('Bougies Bleu Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/bougies_bleu_carte.jpg" alt="Bougies Bleu Carte">
      <p>Carte Bleu - 3€</p>
      <button onclick="addToCart('Bougies Bleu Carte', 3)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/bougies_rose_sticker.jpg" alt="Bougies Rose Sticker">
      <p>Sticker Rose - 1,50€</p>
      <button onclick="addToCart('Bougies Rose Sticker', 1.5)">Ajouter au panier</button>
    </div>
    <div class="product">
      <img src="images/bougies_rose_carte.jpg" alt="Bougies Rose Carte">
      <p>Carte Rose - 3€</p>
      <button onclick="addToCart('Bougies Rose Carte', 3)">Ajouter au panier</button>
    </div>

    <h3>Panier</h3>
    <ul id="cartList"></ul>

  </main>

  <footer>
    <p>&copy; 2026 L'Atelier d'Elia. Tous droits réservés.</p>
  </footer>

  <script>
    let cart = [];

    function addToCart(name, price) {
      cart.push({name, price});
      renderCart();
    }

    function renderCart() {
      const cartList = document.getElementById('cartList');
      cartList.innerHTML = '';
      cart.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item.name + " - " + item.price + "€";
        cartList.appendChild(li);
      });
    }
  </script>
</body>
</html>
