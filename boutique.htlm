      <img src="https://via.placeholder.com/200x200?text=Bougies+Rose" alt="Bougies Rose">
      <p>Carte Rose - 3€</p>
      <button onclick="addToCart('Bougies Rose Carte', 3)">Ajouter au panier</button>
    </div>

    <h3>Panier</h3>
    <ul id="cartList"></ul>

  </main>

  <footer>
    <p>&copy; 2026 L'Atelier d'Elia. Tous droits réservés.</p>
  </footer>

  <script>
    let cart = [];

    function addToCart(name, price) {
      cart.push({name, price});
      renderCart();
    }

    function renderCart() {
      const cartList = document.getElementById('cartList');
      cartList.innerHTML = '';
      cart.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item.name + " - " + item.price + "€";
        cartList.appendChild(li);
      });
    }
  </script>
</body>
</html>
